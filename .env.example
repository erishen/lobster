# Lobster 配置文件

# ==================== 数据模式 ====================
# sample: 使用示例数据（适合演示和测试）
# real: 使用真实数据
DATA_MODE=real

# ==================== API Keys ====================
# 用于获取股票、基金等市场数据

# Alpha Vantage API: https://www.alphavantage.co/support/#api-key
# 免费版：25次/天，支持美股、外汇、加密货币
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Tushare API: https://tushare.pro/register
# 免费版：每日10000次，A股完整数据
TUSHARE_TOKEN=your_tushare_token_here

# Finnhub API: https://finnhub.io/dashboard
# 免费版：美股实时数据
FINNHUB_API_KEY=your_finnhub_key_here

# ==================== AI 配置 ====================
# 方式一：使用中心 API（推荐，无需各项目配独立 Key）
# LLM_API_URL=https://langchain-llm-toolkit.onrender.com
# LLM_API_KEY=your_internal_api_key_here

# 方式二：直接调 DeepSeek / OpenAI
# DEEPSEEK_API_KEY=your_deepseek_key_here
# OPENAI_API_KEY=your_openai_key_here

AI_MODEL=deepseek-chat

# ==================== Serena 配置 ====================
# Serena 安装目录 (用于直接调用 Serena Python API)
# SERENA_DIR=/path/to/serena

# ==================== RAG 知识库配置 ====================
# langchain-llm-toolkit API（与 LLM 共用 LLM_API_URL/LLM_API_KEY）
# 也可单独指定：
# RAG_API_URL=http://localhost:8000

# ==================== 缓存配置 ====================
# API 缓存有效期（秒）
API_CACHE_TTL=60
AI_CACHE_TTL=3600

# ==================== 货币汇率 ====================
DEFAULT_USD_RATE=7.1242
DEFAULT_HKD_RATE=0.9157

# ==================== 输出配置 ====================
OUTPUT_FORMAT=console,csv
REPORT_LANGUAGE=zh
